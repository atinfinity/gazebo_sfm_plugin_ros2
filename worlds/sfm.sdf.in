<?xml version="1.0" ?>
<!--
  Social Force Model pedestrian demo for Gazebo Harmonic (gz-sim8).

  Two actors walk along cyclic trajectories driven by the
  PedestrianSFMRandomPlugin. actor1 drags a kinematic collision cylinder (via
  AttachModelPlugin) so it can be sensed by a LiDAR; actor2 has no collision.

  Only a cylinder collision is supported for the follower body. gz-sim does not
  expose actor skeleton bone poses to plugins, so a follower collision can only
  track the actor's position and yaw (not its leg animation); a Z-symmetric
  cylinder is the only shape that looks correct under that constraint.

  This is a TEMPLATE: @MESH_FILE@ is replaced by sfm.launch.py with the absolute
  path to the bundled meshes/walk.dae before launch (gz mis-resolves relative
  actor skin/animation paths, so an absolute path is required). No internet/Fuel
  download is needed. The actors are defined locally without an SDF <script>
  trajectory: motion and the walking animation are driven entirely by the plugin.
-->
<sdf version="1.10">
  <world name="default">
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>0 -18 8.0 0 0.523 1.5707</pose>
      </camera>
    </gui>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>0 0.5 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>100 100</size></plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>100 100</size></plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Kinematic collision body dragged along with actor1.
         Defined before the actor so AttachModelPlugin can find it. -->
    <model name="actor1_collision_model">
      <pose>0 3 0 0 0 0</pose>
      <link name="link">
        <kinematic>true</kinematic>
        <gravity>false</gravity>
        <inertial>
          <mass>1.0</mass>
          <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz>
                   <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="collision">
          <pose>0 0 0.9 0 0 0</pose>
          <geometry><cylinder><radius>0.45</radius><length>1.5</length></cylinder></geometry>
        </collision>
      </link>
    </model>

    <!-- actor 1: with following collision model -->
    <actor name="actor1">
      <pose>0 3 1.0 0 0 0</pose>
      <skin>
        <filename>@MESH_FILE@</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walking">
        <filename>@MESH_FILE@</filename>
        <scale>1.0</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <plugin filename="PedestrianSFMRandomPlugin"
              name="gazebo_sfm_plugin_ros2::PedestrianSFMRandomPlugin">
        <velocity>1.00</velocity>
        <radius>0.4</radius>
        <animation>walking</animation>
        <animation_factor>5.1</animation_factor>
        <people_distance>6.0</people_distance>
        <goal_weight>2.0</goal_weight>
        <obstacle_weight>80.0</obstacle_weight>
        <social_weight>15</social_weight>
        <group_gaze_weight>3.0</group_gaze_weight>
        <group_coh_weight>2.0</group_coh_weight>
        <group_rep_weight>1.0</group_rep_weight>
        <ignore_obstacles>
          <model>ground_plane</model>
          <model>actor1_collision_model</model>
        </ignore_obstacles>
        <trajectory>
          <cyclic>true</cyclic>
          <waypoint>0 3 1.0</waypoint>
          <waypoint>0 -3 1.0</waypoint>
        </trajectory>
      </plugin>
      <plugin filename="AttachModelPlugin"
              name="servicesim::AttachModelPlugin">
        <link>
          <link_name>Hips</link_name>
          <model>
            <model_name>actor1_collision_model</model_name>
            <pose>0 0 0 0 0 0</pose>
          </model>
        </link>
      </plugin>
    </actor>

    <!-- actor 2: visual only (no collision) -->
    <actor name="actor2">
      <pose>-3 0 1.0 0 0 0</pose>
      <skin>
        <filename>@MESH_FILE@</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walking">
        <filename>@MESH_FILE@</filename>
        <scale>1.0</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <plugin filename="PedestrianSFMRandomPlugin"
              name="gazebo_sfm_plugin_ros2::PedestrianSFMRandomPlugin">
        <velocity>1.00</velocity>
        <radius>0.4</radius>
        <animation>walking</animation>
        <animation_factor>5.1</animation_factor>
        <people_distance>6.0</people_distance>
        <goal_weight>2.0</goal_weight>
        <obstacle_weight>80.0</obstacle_weight>
        <social_weight>15</social_weight>
        <group_gaze_weight>3.0</group_gaze_weight>
        <group_coh_weight>2.0</group_coh_weight>
        <group_rep_weight>1.0</group_rep_weight>
        <ignore_obstacles>
          <model>ground_plane</model>
          <model>actor1_collision_model</model>
        </ignore_obstacles>
        <trajectory>
          <cyclic>true</cyclic>
          <waypoint>-3 0 1.0</waypoint>
          <waypoint>3 0 1.0</waypoint>
        </trajectory>
      </plugin>
    </actor>
  </world>
</sdf>
